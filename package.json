        "@types/lodash.defaultsdeep": "^4.6.9",
        "@types/node": "^22.9.3",
        "@types/react": "18.3.11",
        "@types/react-dom": "18.3.1",
        "@typescript-eslint/eslint-plugin": "^8.47.0",
        "@typescript-eslint/parser": "^8.47.0",
        "classnames": "^2.5.1",
        "eslint": "^9.39.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react": "^7.37.5",
        "globals": "^16.5.0",
